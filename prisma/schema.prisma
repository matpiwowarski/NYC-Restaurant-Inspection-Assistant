generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model HealthCode {
  id        String            @id @default(auto()) @map("_id") @db.ObjectId
  code      String            @unique
  title     String?
  fullText  String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  chunks    HealthCodeChunk[]
}

model HealthCodeChunk {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  embedding Float[]
  code      String

  healthCodeId String     @db.ObjectId
  healthCode   HealthCode @relation(fields: [healthCodeId], references: [id])
}

model Violation {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  code        String
  description String
  embedding   Float[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([code, description])
}
